{
  "name": "@ha-bits/bit-qr",
  "version": "1.0.0",
  "description": "QR code generation and reading bit - supports text, URLs, vCard, WiFi, and calendar data formats",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./driver": {
      "types": "./dist/driver.d.ts",
      "default": "./dist/driver.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "habits",
    "bits",
    "qr",
    "qrcode",
    "barcode",
    "scanner",
    "generator"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "jsqr": "^1.4.0",
    "qrcode": "^1.5.4",
    "image-js": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/qrcode": "^1.5.5",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist"
  ],
  "nx": {
    "sourceRoot": "@ha-bits/bit-qr/src",
    "projectType": "library",
    "tags": [
      "scope:bits",
      "type:bit"
    ],
    "targets": {
      "build": {
        "outputs": [
          "{projectRoot}/dist"
        ]
      },
      "publish-verdaccio": {},
      "publish-npm": {},
      "publish-private": {}
    }
  },
  "habits": {
    "catalog": true,
    "featured": false
  }
}
