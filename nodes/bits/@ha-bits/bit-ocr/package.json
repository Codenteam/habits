{
  "name": "@ha-bits/bit-ocr",
  "version": "1.0.0",
  "description": "OCR bit using Tesseract.js - extract text from images",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./driver": {
      "types": "./dist/driver.d.ts",
      "default": "./dist/driver.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "habits",
    "bits",
    "ocr",
    "tesseract",
    "text-recognition",
    "image",
    "document"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "tesseract.js": "^5.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist"
  ],
  "nx": {
    "sourceRoot": "@ha-bits/bit-ocr/src",
    "projectType": "library",
    "tags": [
      "scope:bits",
      "type:document"
    ]
  },
  "habits": {
    "catalog": true,
    "mobile": false
  }
}
