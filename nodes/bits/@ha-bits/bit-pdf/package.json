{
  "name": "@ha-bits/bit-pdf",
  "version": "1.0.0",
  "description": "PDF processing bit - extract text, images, tables, and metadata from PDF files",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./driver": {
      "types": "./dist/driver.d.ts",
      "default": "./dist/driver.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "habits",
    "bits",
    "pdf",
    "document",
    "extract",
    "text",
    "parsing"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist"
  ],
  "nx": {
    "sourceRoot": "@ha-bits/bit-pdf/src",
    "projectType": "library",
    "tags": [
      "scope:bits",
      "type:document"
    ]
  },
  "habits": {
    "catalog": true,
    "mobile": false
  }
}
