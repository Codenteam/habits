{
  "name": "@ha-bits/bit-email",
  "version": "1.0.4",
  "description": "Email integration bit for IMAP fetching and SMTP sending",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./driver": {
      "types": "./dist/driver.d.ts",
      "default": "./dist/driver.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "habits",
    "bits",
    "email",
    "imap",
    "smtp",
    "mail",
    "nodemailer",
    "imapflow"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "imapflow": "^1.0.171",
    "nodemailer": "^6.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.4.0",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist",
    "src/stubs"
  ],
  "nx": {
    "sourceRoot": "@ha-bits/bit-email/src",
    "projectType": "library",
    "tags": [
      "scope:bits",
      "type:bit"
    ],
    "targets": {
      "build": {
        "outputs": [
          "{projectRoot}/dist"
        ]
      },
      "publish-verdaccio": {},
      "publish-npm": {},
      "publish-private": {}
    }
  },
  "habits": {
    "catalog": true,
    "featured": true,
    "stubs": {
      "@ha-bits/bit-email/driver": "./src/stubs/tauri-driver.js"
    },
    "tauriPlugins": {
      "email": {
        "cargo": "tauri-plugin-email = { path = \"../../habits-cortex/tauri-plugin-email\" }"
      }
    }
  }
}
