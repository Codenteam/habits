{
  "name": "@ha-bits/bit-filesystem",
  "version": "1.0.0",
  "description": "Filesystem operations bit for reading, writing, and managing files",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./driver": {
      "types": "./dist/driver.d.ts",
      "default": "./dist/driver.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "habits",
    "bits",
    "filesystem",
    "files",
    "io",
    "storage"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0"
  },
  "files": [
    "dist",
    "src/stubs"
  ],
  "nx": {
    "sourceRoot": "@ha-bits/bit-filesystem/src",
    "projectType": "library",
    "tags": [
      "scope:bits",
      "type:bit"
    ],
    "targets": {
      "build": {
        "outputs": [
          "{projectRoot}/dist"
        ]
      },
      "publish-verdaccio": {},
      "publish-npm": {},
      "publish-private": {}
    }
  },
  "habits": {
    "catalog": true,
    "featured": false,
    "stubs": {
      "@ha-bits/bit-filesystem/driver": "./src/stubs/tauri-driver.js"
    },
    "tauriPlugins": {
      "fs": {
        "cargo": "tauri-plugin-fs = { version = \"2\" }",
        "init": "tauri_plugin_fs::init()",
        "permissions": ["fs:default", "fs:allow-exists", "fs:allow-read-file", "fs:allow-write-file", "fs:allow-mkdir", "fs:allow-remove", "fs:allow-rename", "fs:allow-copy-file", "fs:allow-read-dir"],
        "scope": ["$APPDATA", "$APPDATA/**"]
      }
    }
  }
}
