    "projectType": "library",
    "tags": [
      "scope:bits",
      "type:bit"
    ],
    "targets": {
      "build": {
        "outputs": [
          "{projectRoot}/dist"
        ]
      },
      "publish-verdaccio": {},
      "publish-npm": {}
    }
