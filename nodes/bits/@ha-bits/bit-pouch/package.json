{
  "name": "@ha-bits/bit-pouch",
  "version": "1.0.0",
  "description": "PouchDB database storage bit - replaces @ha-bits/bit-database with local persistence",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "habits",
    "bits",
    "database",
    "storage",
    "pouchdb",
    "local"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ha-bits/bit-database": "^1.0.0",
    "pouchdb": "^9.0.0",
    "pouchdb-browser": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pouchdb": "^6.4.0",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist"
  ],
  "nx": {
    "sourceRoot": "@ha-bits/bit-pouch/src",
    "projectType": "library",
    "tags": [
      "scope:bits",
      "type:bit"
    ],
    "targets": {
      "build": {
        "outputs": [
          "{projectRoot}/dist"
        ]
      },
      "publish-verdaccio": {},
      "publish-npm": {},
      "publish-private": {}
    }
  },
  "habits": {
    "catalog": true,
    "stubs": {
      "pouchdb": "./dist/stubs/pouchdb.js"
    }
  }
}
