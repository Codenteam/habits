{
  "name": "@ha-bits/bit-database-sql",
  "version": "1.0.1",
  "description": "SQL database storage bit using Drizzle ORM with SQLite support - replaces @ha-bits/bit-database with SQL persistence",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./driver": {
      "types": "./dist/driver.d.ts",
      "default": "./dist/driver.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "habits",
    "bits",
    "database",
    "storage",
    "sql",
    "sqlite",
    "drizzle",
    "orm"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "drizzle-orm": "^0.35.0",
    "better-sqlite3": "^11.0.0",
    "@ha-bits/bit-database": "^1.0.0",
    "sqlite-vec": "^0.1.6"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist",
    "src/stubs"
  ],
  "nx": {
    "sourceRoot": "@ha-bits/bit-database-sql/src",
    "projectType": "library",
    "tags": [
      "scope:bits",
      "type:bit"
    ],
    "targets": {
      "build": {
        "outputs": [
          "{projectRoot}/dist"
        ]
      },
      "publish-verdaccio": {},
      "publish-npm": {},
      "publish-private": {}
    }
  },
  "habits": {
    "catalog": true,
    "featured": true,
    "stubs": {
      "@ha-bits/bit-database-sql/driver": "./src/stubs/tauri-driver.js"
    },
    "tauriPlugins": {
      "sql": {
        "cargo": "tauri-plugin-sql = { version = \"2\", features = [\"sqlite\"] }",
        "init": "tauri_plugin_sql::Builder::default().build()",
        "permissions": [
          "sql:default",
          "sql:allow-load",
          "sql:allow-execute",
          "sql:allow-select"
        ]
      },
      "sqlite-vec": {
        "cargo": "tauri-plugin-sqlite-vec = { path = \"../../../../tauri-plugin-sqlite-vec\" }",
        "init": "tauri_plugin_sqlite_vec::init()",
        "permissions": [
          "sqlite-vec:default",
          "sqlite-vec:allow-ensure-tables",
          "sqlite-vec:allow-vector-insert",
          "sqlite-vec:allow-vector-search",
          "sqlite-vec:allow-vector-delete"
        ]
      }
    }
  }
}
