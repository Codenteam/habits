# Copy this file to .env and fill in your actual values

# Google reCAPTCHA Configuration
# Get your keys from: https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY=
RECAPTCHA_SITE_KEY=

# Mautic Configuration
# Your Mautic instance URL (no trailing slash)
MAUTIC_API_URL=https://mautic.example.com


MAUTIC_CLIENT_ID=your-oauth2-client-id
MAUTIC_CLIENT_SECRET=your-oauth2-client-secret

# Mautic Form ID for form submissions
MAUTIC_FORM_ID=1