@host = localhost
@port = 13000

### Health Check
# @name healthCheck
GET http://{{host}}:{{port}}/health

?? status == 200

### List all workflows
# @name listWorkflows
GET http://{{host}}:{{port}}/misc/workflows

?? status == 200

### Get workflow details - activepieces-github-discord-habits
# @name getWorkflowHabitsDetails
GET http://{{host}}:{{port}}/misc/workflow/activepieces-github-discord-habits

?? status == 200

### Execute GitHub Discord Workflow - New PR Event
# @name executeNewPR
POST http://{{host}}:{{port}}/api/activepieces-github-discord-habits
Content-Type: application/json

{
  "action": "opened",
  "number": 42,
  "pull_request": {
    "title": "Add new feature",
    "user": {
      "login": "test-user"
    },
    "html_url": "https://github.com/test/repo/pull/42"
  },
  "repository": {
    "full_name": "test/repo"
  }
}

?? status >= 200
?? status < 300
