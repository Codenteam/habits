# IMAP to SMTP Email Forward Workflow
# GreenMail Configuration (local testing)
# GreenMail auto-creates any user account on first access
#
# Start GreenMail with port 2525 mapped (required by SMTP piece):
# docker run -d --name greenmail -p 2525:3025 -p 3143:3143 greenmail/standalone:2.0.0

# ===============================
# IMAP Configuration (Incoming Mail)
# ===============================
IMAP_HOST=localhost
IMAP_PORT=3143
IMAP_USERNAME=test@localhost
IMAP_PASSWORD=password
IMAP_MAILBOX=INBOX

# ===============================
# SMTP Configuration (Outgoing Mail)
# ===============================
# Note: SMTP piece only allows ports 25, 465, 587, 2525
SMTP_HOST=localhost
SMTP_PORT=2525
SMTP_EMAIL=forwarder@localhost
SMTP_PASSWORD=password
SMTP_TO=recipient@localhost

# ===============================
# Server Configuration
# ===============================
SERVER_port=13000
