{
  "id": "http-to-text-processing-workflow",
  "name": "HTTP to Text Processing Workflow",
  "description": "Fetch employee data via HTTP and process it with text manipulation",
  "version": "1.0.0",
  "nodes": [
    {
      "id": "webhook-trigger",
      "type": "trigger",
      "position": {
        "x": 100,
        "y": 100
      },
      "data": {
        "label": "Start Workflow",
        "framework": "activepieces",
        "module": "@activepieces/piece-webhook",
        "operation": "webhook",
        "params": {
          "apiUrl": "https://dummy.restapiexample.com/api/v1/employees"
        },
        "credentials": {},
        "inputs": [],
        "outputs": ["main"]
      }
    },
    {
      "id": "http-request",
      "type": "activepieces",
      "position": {
        "x": 400,
        "y": 100
      },
      "data": {
        "label": "Fetch Employee Data",
        "framework": "activepieces",
        "module": "@activepieces/piece-http",
        "operation": "send-request",
        "params": {
          "method": "GET",
          "url": "{{trigger.apiUrl}}",
          "headers": {
            "Content-Type": "application/json",
            "User-Agent": "Habits-Executer/1.0"
          },
          "timeout": 30000
        },
        "credentials": {},
        "inputs": ["main"],
        "outputs": ["main"]
      }
    },
    {
      "id": "text-processing",
      "type": "activepieces", 
      "position": {
        "x": 700,
        "y": 100
      },
      "data": {
        "label": "Process Text Data",
        "framework": "activepieces",
        "module": "@activepieces/piece-text-helper",
        "operation": "concat",
        "params": {
          "text": "{{JSON.stringify(http-request.body)}}",
          "operation": "uppercase"
        },
        "credentials": {},
        "inputs": ["main"],
        "outputs": ["main"]
      }
    }
  ],
  "edges": [
    {
      "id": "edge-1",
      "source": "webhook-trigger",
      "target": "http-request",
      "sourceHandle": "main",
      "targetHandle": "main"
    },
    {
      "id": "edge-2", 
      "source": "http-request",
      "target": "text-processing",
      "sourceHandle": "main",
      "targetHandle": "main"
    }
  ]
}