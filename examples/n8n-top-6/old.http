###############################################################################
# Direct Node Execution Tests (bypassing workflow)
#
# These test the /api/execute endpoint for direct node execution


###############################################################################


### Execute n8n node directly - Text Manipulation
# @name directTextManipulation
# @expected status == 200
# @expected body.status == "completed"
# @expected body.success == true
POST http://{{host}}:{{port}}/api/execute
Content-Type: application/json

{
  "source": "github",
  "framework": "n8n",
  "moduleName": "https://github.com/Bwilliamson55/n8n-nodes-text-manipulation",
  "params": {
    "keepOnlySet": false,
    "textsWithManipulations": {
      "textsWithManipulationsValues": [
        {
          "dataSources": {
            "dataSource": [
              {
                "readOperation": "fromText",
                "text": "  HELLO WORLD!  "
              }
            ]
          },
          "manipulations": {
            "manipulation": [
              {
                "manipulationType": "trim"
              }
            ]
          },
          "writeToOutputAs": {
            "writeToOutputAsValues": [
              {
                "writeOperation": "toJSON",
                "jsonPropertyName": "result"
              }
            ]
          }
        }
      ]
    },
    "inputData": [
      {
        "json": {}
      }
    ]
  }
}


### Execute n8n node directly - Global Constants
# @name directGlobalConstants
# @expected status == 200
# @expected body.status == "completed"
# @expected body.success == true
POST http://{{host}}:{{port}}/api/execute
Content-Type: application/json

{
  "source": "github",
  "framework": "n8n",
  "moduleName": "https://github.com/digital-boss/n8n-nodes-globals",
  "params": {
    "putAllInOneKey": true,
    "constantsKeyName": "config",
    "credentials": {
      "globalConstantsApi": {
        "format": "string",
        "globalConstants": "APP_NAME=TestApp\nVERSION=1.0\nDEBUG=true"
      }
    },
    "inputData": [
      {
        "json": {
          "test": "data"
        }
      }
    ]
  }
}


### Execute n8n node directly - ElevenLabs TTS
# @name directElevenLabsTTS
# Note: Requires valid ELEVENLABS_API_KEY
# @expected status == 200
# @expected body.status in ["completed", "failed"]
POST http://{{host}}:{{port}}/api/execute
Content-Type: application/json

{
  "source": "github",
  "framework": "n8n",
  "moduleName": "https://github.com/elevenlabs/elevenlabs-n8n",
  "params": {
    "resource": "speech",
    "operation": "textToSpeech",
    "voice": {
      "mode": "id",
      "value": "21m00Tcm4TlvDq8ikWAM"
    },
    "text": "Hello, this is a test.",
    "credentials": {
      "elevenLabsApi": {
        "xiApiKey": "YOUR_ELEVENLABS_API_KEY"
      }
    }
  }
}


