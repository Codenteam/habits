@host = localhost
@port = 3000


###############################################################################
# Health & Workflow List
#
# Expected Responses:
# - Health: { "status": "healthy", "workflowsLoaded": 6 }
# - Workflows: { "count": 6, "workflows": [...] }


###############################################################################


### Health Check
# @name healthCheck
# @expected status == 200
# @expected body.status == "healthy"
# @expected body.workflowsLoaded == 6
# @expected body.configLoaded == true
GET http://{{host}}:{{port}}/health


### List all workflows
# @name listWorkflows
# @expected status == 200
# @expected body.count == 6
# @expected body.workflows[0].id == "elevenlabs-tts"
# @expected body.workflows[1].id == "text-manipulation"
# @expected body.workflows[2].id == "global-constants"
# @expected body.workflows[3].id == "chatwoot-contact"
# @expected body.workflows[4].id == "evolution-api"
# @expected body.workflows[5].id == "mcp-client"
GET http://{{host}}:{{port}}/misc/workflows


###############################################################################
# 1. ElevenLabs Text-to-Speech Workflow
#
# Expected: Workflow exists, execution requires valid API key


###############################################################################


### Get ElevenLabs workflow details
# @name getElevenLabsWorkflow
# @expected status == 200
# @expected body.id == "elevenlabs-tts"
# @expected body.name == "ElevenLabs Text-to-Speech"
# @expected body.enabled == true
GET http://{{host}}:{{port}}/misc/workflow/elevenlabs-tts


### Execute ElevenLabs TTS - Convert text to speech
# @name executeElevenLabsTTS
# Note: Requires valid ELEVENLABS_API_KEY in environment
# @expected status == 200
# @expected body.workflowId == "elevenlabs-tts"
# @expected body.status in ["completed", "failed"]
POST http://{{host}}:{{port}}/api/elevenlabs-tts
Content-Type: application/json

{
  "text": "Hello! This is a test of the ElevenLabs text to speech API.",
  "voice": {
    "mode": "id",
    "value": "21m00Tcm4TlvDq8ikWAM"
  }
}


###############################################################################
# 2. Text Manipulation Workflow
#
# Expected: Successfully trims and processes text input


###############################################################################


### Get Text Manipulation workflow details
# @name getTextManipulationWorkflow
# @expected status == 200
# @expected body.id == "text-manipulation"
# @expected body.name == "Text Manipulation"
# @expected body.enabled == true
GET http://{{host}}:{{port}}/misc/workflow/text-manipulation


### Execute Text Manipulation - Trim and lowercase
# @name executeTextManipulation
# @expected status == 200
# @expected body.workflowId == "text-manipulation"
# @expected body.status == "completed"
# @expected body.nodeResults[0].status == "completed"
# @expected body.nodeResults[0].nodeName == "Text Manipulation"
POST http://{{host}}:{{port}}/api/text-manipulation
Content-Type: application/json

{
  "inputData": [
    {
      "json": {
        "originalText": "  HELLO WORLD!  This is a TEST.  "
      }
    }
  ]
}


