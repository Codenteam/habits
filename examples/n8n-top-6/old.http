POST http://{{host}}:{{port}}/api/global-constants
Content-Type: application/json

{
  "inputData": [
    {
      "json": {
        "requestId": "test-123",
        "timestamp": "2024-01-01T00:00:00Z"
      }
    }
  ]
}


