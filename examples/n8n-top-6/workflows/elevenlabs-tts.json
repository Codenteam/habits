{
  "id": "elevenlabs-tts",
  "name": "ElevenLabs Text-to-Speech",
  "description": "Convert text to speech using ElevenLabs API",
  "version": "1.0.0",
  "nodes": [
    {
      "id": "elevenlabs-tts-node",
      "type": "n8n",
      "position": { "x": 250, "y": 100 },
      "data": {
        "label": "Text to Speech",
        "framework": "n8n",
        "source": "npm",
        "module": "@elevenlabs/n8n-nodes-elevenlabs",
        "resource": "speech",
        "operation": "textToSpeech",
        "params": {
          "voice": "{{habits.input.voice}}",
          "text": "{{habits.input.text}}",
          "inputData": "{{habits.input.inputData}}"
        },
        "credentials": {
          "elevenLabsApi": {
            "xiApiKey": "{{habits.env.HABITS_ELEVENLABS_API_KEY}}"
          }
        }
      }
    }
  ],
  "edges": []
}
