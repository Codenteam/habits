{
  "id": "evolution-api",
  "name": "Evolution API - Fetch Instances",
  "description": "Fetch WhatsApp instances using Evolution API",
  "version": "1.0.0",
  "nodes": [
    {
      "id": "evolution-api-node",
      "type": "n8n",
      "position": { "x": 250, "y": 100 },
      "data": {
        "label": "Fetch Instances",
        "framework": "n8n",
        "source": "npm",
        "module": "@ahmed-kamal/n8n-nodes-evolution-api",
        "resource": "instances-api",
        "operation": "fetch-instances",
        "params": {
          "instanceName": "{{habits.input.instanceName}}",
          "inputData": "{{habits.input.inputData}}"
        },
        "credentials": {
          "evolutionApi": {
            "server-url": "{{habits.env.HABITS_EVOLUTION_API_URL}}",
            "apikey": "{{habits.env.HABITS_EVOLUTION_API_KEY}}"
          }
        }
      }
    }
  ],
  "edges": []
}
