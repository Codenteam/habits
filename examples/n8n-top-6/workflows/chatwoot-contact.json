{
  "id": "chatwoot-contact",
  "name": "ChatWoot Contact Search and Send Message",
  "description": "Search for contacts in ChatWoot, get their conversations, and send a message",
  "version": "1.0.0",
  "nodes": [
    {
      "id": "chatwoot_contact_node",
      "type": "n8n",
      "position": { "x": 250, "y": 100 },
      "data": {
        "label": "ChatWoot Contact Search",
        "framework": "n8n",
        "source": "npm",
        "module": "n8n-nodes-chatwoot",
        "operation": "contactSearch",
        "params": {
          "authentication": "parametersCredentialType",
          "baseUrl": "{{habits.env.HABITS_CHATWOOT_BASE_URL}}",
          "accessToken": "{{habits.env.HABITS_CHATWOOT_ACCESS_TOKEN}}",
          "resource": "contact",
          "operation": "contactSearch",
          "accountId": "{{habits.env.HABITS_CHATWOOT_ACCOUNT_ID}}",
          "contactSearchQuery": "{{habits.input.query}}"
        },
        "credentials": {}
      }
    },
    {
      "id": "chatwoot_conversations_node",
      "type": "n8n",
      "position": { "x": 500, "y": 100 },
      "data": {
        "label": "ChatWoot Create Conversation",
        "framework": "n8n",
        "source": "npm",
        "module": "n8n-nodes-chatwoot",
        "operation": "conversation",
        "params": {
          "authentication": "parametersCredentialType",
          "baseUrl": "{{habits.env.HABITS_CHATWOOT_BASE_URL}}",
          "resource": "public",
          "operation": "conversation",
          "inboxIdentifier": "{{habits.env.HABITS_CHATWOOT_INBOX_IDENTIFIER}}",
          "sourceId": "{{chatwoot_contact_node.result.0.0.json.payload.0.contact_inboxes.0.source_id}}"
        },
        "credentials": {}
      }
    },
    {
      "id": "chatwoot_send_message_node",
      "type": "n8n",
      "position": { "x": 750, "y": 100 },
      "data": {
        "label": "ChatWoot Send Message",
        "framework": "n8n",
        "source": "npm",
        "module": "n8n-nodes-chatwoot",
        "operation": "messageCreate",
        "params": {
          "authentication": "parametersCredentialType",
          "baseUrl": "{{habits.env.HABITS_CHATWOOT_BASE_URL}}",
          "resource": "public",
          "operation": "messageCreate",
          "inboxIdentifier": "{{habits.env.HABITS_CHATWOOT_INBOX_IDENTIFIER}}",
          "sourceId": "{{chatwoot_contact_node.result.0.0.json.payload.0.contact_inboxes.0.source_id}}",
          "conversationId": "{{chatwoot_conversations_node.result.0.0.json.id}}",
          "content": "{{habits.input.message}}"
        },
        "credentials": {}
      }
    }
  ],
  "edges": [
    {
      "id": "edge-1",
      "source": "chatwoot_contact_node",
      "target": "chatwoot_conversations_node"
    },
    {
      "id": "edge-2",
      "source": "chatwoot_conversations_node",
      "target": "chatwoot_send_message_node"
    }
  ]
}
