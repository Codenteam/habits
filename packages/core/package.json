{
  "name": "@ha-bits/core",
  "version": "1.0.0",
  "description": "Core - Shared types and utilities for Habits ecosystem",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "habits",
    "workflow",
    "types",
    "core"
  ],
  "author": "Codenteam",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/codenteam/habits.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  }
}
