{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@ha-bits/core": ["../../../packages/core/src/index.ts"],
      "@ha-bits/core/*": ["../../../packages/core/src/*"],
      "@ha-bits/frontend-builder": ["../frontend-builder/src/index.ts"],
      "@ha-bits/frontend-builder/*": ["../frontend-builder/src/*"],
      "@ha-bits/workflow-canvas": ["../../workflow-canvas/src/index.ts"],
      "@ha-bits/workflow-canvas/*": ["../../workflow-canvas/src/*"],
      "@habits/shared/types": ["../../../packages/core/src/types.ts"],
      "@habits/shared/*": ["../../../packages/core/src/*"],
      "@/*": ["./src/*"]
      
    }
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
