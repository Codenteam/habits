{
  "name": "@ha-bits/base",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/base/server/src",
  "projectType": "application",
  "tags": [
    "scope:executor"
  ],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": [
        "{workspaceRoot}/dist/packages/base"
      ],
      "options": {
        "outputPath": "dist/packages/base/server",
        "main": "packages/base/server/src/main.ts",
        "outputFileName": "main.cjs",
        "tsConfig": "packages/base/server/tsconfig.lib.json",
        "platform": "node",
        "format": ["cjs"],
        "bundle": true,
            "thirdParty": true,

        "sourcemap": true,
        "declaration": false,
        "generatePackageJson": false,
        "packages": "bundle",
        "minify": true,
        "assets": [
          {
            "input": "packages/base/server",
            "glob": "package.json",
            "output": ".."
          },
          {
            "input": "packages/base/server",
            "glob": "README.md",
            "output": ".."
          },
          {
            "input": "packages/base/server/src",
            "glob": "sea-entry-template.js",
            "output": "."
          }, 
          {
            "input": "packages/base/server/assets",
            "glob": "**/*",
            "output": "assets"
          },
          {
            "input": "assets",
            "glob": "**/*",
            "output": "assets"
          }
        ],
        "esbuildOptions": {
          "banner": {
            "js": "#!/usr/bin/env node"
          },
          "external": [
            "@activepieces/*",
            "@tailwindcss/postcss",
            "@tailwindcss/oxide",
            "@tailwindcss/oxide-*",
            "lightningcss"
          ],
          "packages": "bundle"
        }
      },
      "dependsOn": [
        "^build",
        "@ha-bits/base-ui:build"
      ]
    },
    "publish": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "chmod +x dist/packages/base/server/main.cjs",
          "cd packages/base && npm version patch --no-git-tag-version",
          "cd dist/packages/base && npm publish"
        ],
        "parallel": false
      },
      "dependsOn": [
        "build"
      ]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["pnpm tsx watch packages/base/server/src/main.ts server"],
        "parallel": true,
        "cwd": "{workspaceRoot}"
      }
    },
    "ts-node": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm ts-node packages/base/server/src/main.ts server",
        "cwd": "{workspaceRoot}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm tsc -p packages/base/server/tsconfig.lib.json --noEmit"
      }
    }
  }
}
