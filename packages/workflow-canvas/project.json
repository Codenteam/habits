{
  "name": "@ha-bits/workflow-canvas",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/workflow-canvas/src",
  "projectType": "library",
  "tags": [
    "scope:shared",
    "type:library"
  ],
  "targets": {
    "build": {
      "executor": "@nx/vite:build",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/packages/workflow-canvas",
        "root": "packages/workflow-canvas"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm vite build --watch",
        "cwd": "packages/workflow-canvas"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm tsc -p packages/workflow-canvas/tsconfig.json --noEmit"
      }
    }
  }
}
