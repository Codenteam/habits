{
  "name": "@ha-bits/test-utils",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/test-utils/src",
  "projectType": "library",
  "tags": ["scope:testing"],
  "targets": {
    "build": false,
    "test-bits": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node dist/packages/test-utils/src/cli.js",
        "cwd": "{workspaceRoot}",
        "args": ["-v"]
      }
    },
    "test-bit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node dist/packages/test-utils/src/cli.js -f {args.bit} -v",
        "cwd": "{workspaceRoot}"
      },
      "configurations": {
        "default": {}
      }
    }
  }
}
