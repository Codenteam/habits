{
  "name": "@ha-bits/cortex",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/cortex/server/src",
  "projectType": "application",
  "tags": [
    "scope:executor"
  ],
  "targets": {
    "build": {
      
      "executor": "@nx/esbuild:esbuild",
      "outputs": [
        "{workspaceRoot}/dist/packages/cortex"
      ],
      "options": {
        "outputPath": "dist/packages/cortex/server",
        "main": "packages/cortex/server/src/main.ts",
        "outputFileName": "main.cjs",
        "tsConfig": "packages/cortex/server/tsconfig.lib.json",
        "platform": "node",
        "format": ["cjs", "esm"],
        "bundle": true,
        "sourcemap": true,
        "metadata": true,
        "declaration": false,
        "assets": [
          {
            "input": "packages/cortex/server",
            "glob": "package.json",
            "output": ".."
          },
          {
            "input": "packages/cortex/server",
            "glob": "README.md",
            "output": ".."
          }
        ],
        "esbuildOptions": {
          "banner": {
            "js": "#!/usr/bin/env node"
          },
          "packages": "bundle"
        }
      },
      "dependsOn": [
        "^build",
        "@ha-bits/cortex-ui:build"
      ]
    },
    "publish": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "npm version ${NPM_VERSION:-patch} --no-git-tag-version --allow-same-version",
          "npm publish --tag ${NPM_TAG:-latest} --access public"
        ],
        "cwd": "dist/packages/cortex/server",
        "parallel": false
      },
      "dependsOn": [
        "build"
      ]
    },

    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm tsx watch packages/cortex/server/src/main.ts server --config {args.config}",
        "cwd": "{workspaceRoot}",
        "config": "showcase/marketing-campaign/config.json"
      }
    },
        
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./packages/cortex/server/exec {args.testName}",
        "cwd": "{workspaceRoot}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm tsc -p packages/cortex/server/tsconfig.lib.json --noEmit"
      }
    },
    "build-lib": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": [
        "{workspaceRoot}/dist/packages/cortex/lib"
      ],
      "options": {
        "outputPath": "dist/packages/cortex/lib",
        "main": "packages/cortex/server/src/index.ts",
        "outputFileName": "index.cjs",
        "tsConfig": "packages/cortex/server/tsconfig.lib.json",
        "platform": "node",
        "format": ["cjs"],
        "bundle": true,
        "sourcemap": false,
        "declaration": false,
        "esbuildOptions": {
          "packages": "bundle"
        }
      },
      "dependsOn": [
        "^build",
        "@ha-bits/cortex-ui:build"
      ]
    }
  }
}
