{
  "name": "@local-ai/node",
  "version": "0.1.0",
  "description": "Node.js bindings for Local AI inference - text generation, image captioning, image generation, audio transcription, and text-to-voice",
  "main": "index.js",
  "types": "index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/local-ai-candle"
  },
  "license": "MIT OR Apache-2.0",
  "keywords": [
    "ai",
    "machine-learning",
    "inference",
    "whisper",
    "stable-diffusion",
    "llm",
    "text-generation",
    "image-captioning",
    "text-to-speech",
    "napi-rs",
    "native"
  ],
  "engines": {
    "node": ">= 18"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "*.node"
  ],
  "napi": {
    "name": "local-ai-node",
    "triples": {
      "defaults": true,
      "additional": [
        "x86_64-apple-darwin",
        "aarch64-apple-darwin",
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu",
        "x86_64-pc-windows-msvc"
      ]
    }
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "node scripts/build.js",
    "build:cpu": "npx napi build --platform --release",
    "build:metal": "npx napi build --platform --release --features metal,accelerate",
    "build:cuda": "npx napi build --platform --release --features cuda",
    "build:debug": "npx napi build --platform",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "node --test test/",
    "version": "napi version"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4",
    "typescript": "^5.3.0"
  },
  "optionalDependencies": {
    "@local-ai/node-darwin-arm64": "0.1.0",
    "@local-ai/node-darwin-x64": "0.1.0",
    "@local-ai/node-linux-arm64-gnu": "0.1.0",
    "@local-ai/node-linux-x64-gnu": "0.1.0",
    "@local-ai/node-win32-x64-msvc": "0.1.0"
  }
}
