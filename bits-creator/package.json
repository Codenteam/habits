{
  "name": "@bits/creator",
  "version": "1.0.0",
  "description": "Code converter and generator using GitHub Copilot SDK - converts or generates code based on specs, instructions, and types",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "d": "pnpm tsx scripts/dev.ts",
    "prepare": "husky",
    "build": "tsc",
    "dev": "tsx watch src/run-conversion.ts",
    "dev:cli": "tsx scripts/dev.ts",
    "start": "tsx src/cli.ts",
    "cli": "tsx src/cli.ts",
    "convert": "tsx src/cli.ts --convert",
    "generate": "tsx src/cli.ts --prompt",
    "example": "tsx src/run-conversion.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.1.20",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.19.7",
    "husky": "^9.1.7",
    "nx": "^21.3.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "copilot",
    "code-converter",
    "code-generator",
    "ai",
    "typescript",
    "bits"
  ]
}
