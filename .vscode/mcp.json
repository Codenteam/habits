{
  "servers": {
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    },
    "habits-mcp": {
      "command": "npx",
      "args": [
        "tsx",
        "${workspaceFolder}/packages/manage/forge/src/mcp/habits-mcp.ts"
      ],
      "env": {
        "WEBDRIVER_PORT": "4445",
        "WEBDRIVER_HOST": "127.0.0.1",
        "MANAGE_ADMIN_URL": "http://localhost:8080",
        "MANAGE_PDNS_API_URL": "http://localhost:8081",
        "MANAGE_PDNS_SERVER_ID": "localhost",
        "MANAGE_ROOT_DOMAIN": "habits.local",
        "WORKSPACE_ROOT": "${workspaceFolder}"
      }
    }
  }
}
