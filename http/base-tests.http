@host = http://localhost
@port = 3000

# =============================================================================
# Base Mode API Tests
# =============================================================================
# 
# This file tests all Base mode endpoints when running:
#   npx habits base
#   OR
#   npx ./dist/packages/habits base (local testing)
#
# Run all tests:
#   httpyac http/base-tests.http --all
#
# Run specific test:
#   httpyac http/base-tests.http -n "Base UI Health"
#
# =============================================================================

# =============================================================================
# UI Health Checks
# =============================================================================

### Base UI Health - React SPA
# @name baseUIHealth
GET {{host}}:{{port}}/habits/base/

?? status == 200

### Base UI - Deep Route (SPA fallback)
# @name baseUIDeepRoute
GET {{host}}:{{port}}/habits/base/some/deep/route

?? status == 200

# =============================================================================
# API Health Checks
# =============================================================================

### Base API Health
# @name baseAPIHealth
GET {{host}}:{{port}}/habits/base/api

?? status == 200

### Base API - Modules List
# @name modulesListAPI
GET {{host}}:{{port}}/habits/base/api/modules
Content-Type: application/json

?? status == 200

# =============================================================================
# Templates API - /templates/:templateName/{*filePath}
# =============================================================================

### Get mixed template - stack.yaml
# @name mixedStackYaml
GET {{host}}:{{port}}/habits/base/api/templates/mixed/stack.yaml
Content-Type: application/json

?? status == 200

### Get business-intersect-standalone template - stack.yaml
# @name businessStackYaml
GET {{host}}:{{port}}/habits/base/api/templates/business-intersect-standalone/stack.yaml
Content-Type: application/json

?? status == 200

### Get business-intersect-standalone template - habit.yaml
# @name businessHabitYaml
GET {{host}}:{{port}}/habits/base/api/templates/business-intersect-standalone/habit.yaml
Content-Type: application/json

?? status == 200

### Test 404 - Non-existent template
# @name template404
GET {{host}}:{{port}}/habits/base/api/templates/non-existent-template/stack.yaml
Content-Type: application/json

?? status == 404

### Test 404 - Non-existent file in existing template
# @name templateFile404
GET {{host}}:{{port}}/habits/base/api/templates/mixed/non-existent-file.yaml
Content-Type: application/json

?? status == 404

# =============================================================================
# Module Schema API
# =============================================================================

### Get module schema - Bits HTTP
# @name moduleSchemaHTTP
GET {{host}}:{{port}}/habits/base/api/modules/schema/bits/@ha-bits%2Fbit-http
Content-Type: application/json

?? status == 200

### Check module availability - Bits HTTP
# @name moduleCheckHTTP
GET {{host}}:{{port}}/habits/base/api/modules/check/bits/@ha-bits%2Fbit-http
Content-Type: application/json

?? status == 200

# =============================================================================
# Module Execution API
# =============================================================================

### Execute module - Bits HTTP (example)
# @name executeModule
POST {{host}}:{{port}}/habits/base/api/execute
Content-Type: application/json

{
  "module": "bits/@ha-bits/bit-http",
  "params": {
    "method": "GET",
    "url": "https://httpbin.org/get"
  }
}

# =============================================================================
# Forms API - Dynamic Options
# =============================================================================

### Populate form options
# @name populateOptions
POST {{host}}:{{port}}/habits/base/api/forms/populate-options
Content-Type: application/json

{
  "framework": "bits",
  "moduleId": "@ha-bits/bit-intersect",
  "actionName": "send_prompt",
  "fieldName": "model",
  "currentValues": {}
}
