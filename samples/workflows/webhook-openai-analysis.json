{
  "name": "Webhook to OpenAI Analysis",
  "description": "Receive webhook data and analyze it with OpenAI",
  "steps": [
    {
      "id": "webhook-trigger",
      "type": "trigger",
      "framework": "activepieces",
      "module": "piece-webhook",
      "params": {
        "method": "POST",
        "path": "/webhook/analyze",
        "triggerCondition": "result && result.data"
      }
    },
    {
      "id": "openai-analysis",
      "type": "action",
      "framework": "activepieces",
      "module": "piece-openai",
      "params": {
        "connection": "{{process.env.OPENAI_CONNECTION}}",
        "model": "gpt-4",
        "messages": [
          {
            "role": "user",
            "content": "Analyze this data and provide insights: {{previous_result.data}}"
          }
        ],
        "temperature": 0.7,
        "max_tokens": 500
      }
    },
    {
      "id": "log-results",
      "type": "action",
      "framework": "activepieces",
      "module": "piece-logger",
      "params": {
        "level": "info",
        "message": "Analysis completed",
        "data": {
          "original_data": "{{step_webhook-trigger.data}}",
          "analysis": "{{step_openai-analysis.choices[0].message.content}}",
          "timestamp": "{{new Date().toISOString()}}"
        }
      }
    }
  ]
}