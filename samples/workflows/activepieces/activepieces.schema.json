{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Activepieces Workflow Schema",
    "description": "Schema for Activepieces workflow configuration",
    "type": "object",
    "required": ["displayName", "trigger"],
    "properties": {
        "displayName": {
            "type": "string",
            "description": "The display name of the workflow"
        },
        "trigger": {
            "type": "object",
            "description": "The trigger that starts the workflow",
            "required": ["type", "settings"],
            "properties": {
                "type": {
                    "type": "string",
                    "enum": ["PIECE_TRIGGER", "SCHEDULE", "WEBHOOK"]
                },
                "settings": {
                    "type": "object",
                    "properties": {
                        "pieceName": {
                            "type": "string"
                        },
                        "pieceVersion": {
                            "type": "string"
                        },
                        "triggerName": {
                            "type": "string"
                        },
                        "input": {
                            "type": "object"
                        },
                        "cronExpression": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "actions": {
            "type": "array",
            "description": "List of actions to execute in the workflow",
            "items": {
                "type": "object",
                "required": ["name", "type", "settings"],
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "displayName": {
                        "type": "string"
                    },
                    "type": {
                        "type": "string",
                        "enum": ["PIECE", "CODE", "BRANCH", "LOOP"]
                    },
                    "settings": {
                        "type": "object",
                        "properties": {
                            "pieceName": {
                                "type": "string"
                            },
                            "pieceVersion": {
                                "type": "string"
                            },
                            "actionName": {
                                "type": "string"
                            },
                            "input": {
                                "type": "object"
                            },
                            "sourceCode": {
                                "type": "string"
                            }
                        }
                    },
                    "nextAction": {
                        "type": "object"
                    }
                }
            }
        },
        "schedule": {
            "type": "object",
            "properties": {
                "type": {
                    "type": "string",
                    "enum": ["CRON"]
                },
                "cronExpression": {
                    "type": "string"
                }
            }
        }
    }
}