{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "n8n Workflow Schema",
    "description": "Schema for n8n workflow JSON structure",
    "type": "object",
    "required": ["name", "nodes", "connections"],
    "properties": {
        "name": {
            "type": "string",
            "description": "The name of the workflow"
        },
        "nodes": {
            "type": "array",
            "description": "Array of nodes in the workflow",
            "items": {
                "type": "object",
                "required": ["parameters", "name", "type", "typeVersion", "position"],
                "properties": {
                    "parameters": {
                        "type": "object",
                        "description": "Node-specific parameters"
                    },
                    "name": {
                        "type": "string",
                        "description": "Name of the node"
                    },
                    "type": {
                        "type": "string",
                        "description": "Type of the node"
                    },
                    "typeVersion": {
                        "type": "number",
                        "description": "Version of the node type"
                    },
                    "position": {
                        "type": "array",
                        "description": "Position of the node [x, y]",
                        "items": {
                            "type": "number"
                        },
                        "minItems": 2,
                        "maxItems": 2
                    },
                    "id": {
                        "type": "string",
                        "description": "Unique identifier for the node"
                    },
                    "credentials": {
                        "type": "object",
                        "description": "Credentials used by the node"
                    }
                }
            }
        },
        "connections": {
            "type": "object",
            "description": "Connections between nodes",
            "additionalProperties": {
                "type": "object",
                "additionalProperties": {
                    "type": "array",
                    "items": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "node": {
                                    "type": "string",
                                    "description": "Target node name"
                                },
                                "type": {
                                    "type": "string",
                                    "description": "Connection type"
                                },
                                "index": {
                                    "type": "number",
                                    "description": "Connection index"
                                }
                            }
                        }
                    }
                }
            }
        },
        "active": {
            "type": "boolean",
            "description": "Whether the workflow is active"
        },
        "settings": {
            "type": "object",
            "description": "Workflow settings"
        },
        "tags": {
            "type": "array",
            "description": "Tags associated with the workflow",
            "items": {
                "type": "string"
            }
        },
        "id": {
            "type": "string",
            "description": "Unique identifier for the workflow"
        }
    }
}