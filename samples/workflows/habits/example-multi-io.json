{
  "id": "example-workflow-multi-io",
  "name": "Multi Input/Output Example",
  "description": "Example workflow demonstrating nodes with multiple inputs and outputs",
  "version": "1.0.0",
  "nodes": [
    {
      "id": "node-trigger",
      "type": "n8n",
      "position": { "x": 100, "y": 100 },
      "data": {
        "label": "Schedule Trigger",
        "framework": "n8n",
        "module": "n8n-schedule-trigger",
        "resource": "schedule",
        "operation": "trigger",
        "params": {
          "interval": "daily"
        },
        "inputs": [],
        "outputs": ["main"]
      }
    },
    {
      "id": "node-if",
      "type": "n8n",
      "position": { "x": 300, "y": 100 },
      "data": {
        "label": "Condition Check",
        "framework": "n8n",
        "module": "n8n-if",
        "resource": "logic",
        "operation": "if",
        "params": {
          "condition": "{{ $json.value > 10 }}"
        },
        "inputs": ["main"],
        "outputs": ["main", "false"]
      }
    },
    {
      "id": "node-merge",
      "type": "n8n",
      "position": { "x": 500, "y": 200 },
      "data": {
        "label": "Merge Data",
        "framework": "n8n",
        "module": "n8n-merge",
        "resource": "data",
        "operation": "merge",
        "params": {
          "mode": "append"
        },
        "inputs": ["main", "main"],
        "outputs": ["main"]
      }
    },
    {
      "id": "node-switch",
      "type": "n8n",
      "position": { "x": 700, "y": 100 },
      "data": {
        "label": "Route Data",
        "framework": "n8n",
        "module": "n8n-switch",
        "resource": "logic",
        "operation": "switch",
        "params": {
          "rules": [
            {"condition": "{{ $json.type === 'A' }}"},
            {"condition": "{{ $json.type === 'B' }}"},
            {"condition": "{{ $json.type === 'C' }}"}
          ]
        },
        "inputs": ["main"],
        "outputs": ["0", "1", "2", "3"]
      }
    }
  ],
  "edges": [
    {
      "id": "edge-1",
      "source": "node-trigger",
      "target": "node-if",
      "sourceHandle": "main",
      "targetHandle": "main"
    },
    {
      "id": "edge-2",
      "source": "node-if",
      "target": "node-merge",
      "sourceHandle": "main",
      "targetHandle": "main"
    },
    {
      "id": "edge-3",
      "source": "node-if",
      "target": "node-merge",
      "sourceHandle": "false",
      "targetHandle": "main"
    },
    {
      "id": "edge-4",
      "source": "node-merge",
      "target": "node-switch",
      "sourceHandle": "main",
      "targetHandle": "main"
    }
  ]
}