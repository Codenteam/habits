#!/bin/bash

# Pre-push hook - delegates to shared validation script
# This ensures consistency between local checks and CI

bash scripts/validate-affected.sh origin/main false

# Ensure COMMANDS.md is not stale relative to commands.ts
npx tsx packages/manage/forge/src/mcp/commands.ts > /dev/null 2>&1
if ! git diff --quiet COMMANDS.md; then
  echo ""
  echo "❌ COMMANDS.md is out of sync with commands.ts."
  echo "   Run: pnpm nx generate-commands @ha-bits/manage"
  echo "   Then commit the updated COMMANDS.md before pushing."
  git checkout COMMANDS.md  # restore to avoid leaving a dirty working tree
  exit 1
fi
