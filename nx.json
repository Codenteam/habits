{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "workspaceLayout": {
    "appsDir": "packages",
    "libsDir": "packages"
  },
  "plugins": [
    {
      "plugin": "@nx/js/typescript",
      "include": ["packages/**/*", "nodes/activepieces/@ha-bits/piece-*/**/*"],
      "exclude": ["node_modules/**/*", "docs/**/*", "workflows/**/*", "samples/**/*"]
    }
  ],
  "extends": "nx/presets/npm.json",
  "tasksRunnerOptions": {
    "default": {
      "runner": "nx/tasks-runners/default"
    }
  },
  "useInferencePlugins": false,
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*",
      "sharedGlobals"
    ],
    "production": [
      "default",
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)",
      "!{projectRoot}/tsconfig.spec.json",
      "!{projectRoot}/.eslintrc.json"
    ],
    "sharedGlobals": []
  },
  "targetDefaults": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "production",
        "^production"
      ],
      "cache": true
    },
    "typecheck": {
      "cache": true
    },
    "pack-cjs": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "pnpm esbuild {args.input} --bundle --platform=node --format=cjs --outfile={args.output} --external:@activepieces/* --minify{args.banner}"
        ],
        "cwd": "{workspaceRoot}",
        "parallel": false,
        "banner": " --banner:js='#!/usr/bin/env node'"
      },
      "dependsOn": [
        "build"
      ],
      "cache": true
    },
    "pack-esm": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "pnpm esbuild {args.input} --bundle --platform=node --format=esm --outfile={args.output} --external:@activepieces/* --minify"
        ],
        "cwd": "{workspaceRoot}",
        "parallel": false
      },
      "dependsOn": [
        "build"
      ],
      "cache": true
    },
    "pack": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["echo 'Pack completed'"],
        "cwd": "{workspaceRoot}",
        "parallel": false
      },
      "dependsOn": [
        "pack-esm"
      ],
      "cache": false
    }
  },
  "defaultBase": "main"
}
