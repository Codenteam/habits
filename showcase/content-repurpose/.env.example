# Content Repurposer - Environment Variables
# Copy this file to .env and fill in your credentials

# ===========================================
# REQUIRED: OpenAI API Key
# ===========================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# ===========================================
# OPTIONAL: LinkedIn OAuth Tokens
# ===========================================
# Option 1: Provide tokens directly (bypasses OAuth callback flow)
# Obtain tokens from LinkedIn Developer Portal or via OAuth flow
# https://www.linkedin.com/developers/

# Access token (required for posting)
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token

# Refresh token (optional, enables automatic token refresh)
LINKEDIN_REFRESH_TOKEN=your-linkedin-refresh-token

# Option 2: For OAuth callback flow (if not providing tokens directly)
# LINKEDIN_CLIENT_ID=your-linkedin-client-id
# LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# ===========================================
# OPTIONAL: Twitter/X OAuth Tokens
# ===========================================
# Option 1: Provide tokens directly (bypasses OAuth callback flow)
# Obtain tokens from Twitter Developer Portal or via OAuth flow
# https://developer.twitter.com/

# Access token (required for posting)
TWITTER_ACCESS_TOKEN=your-twitter-access-token

# Refresh token (optional, enables automatic token refresh)
TWITTER_REFRESH_TOKEN=your-twitter-refresh-token

# Option 2: For OAuth callback flow (if not providing tokens directly)
# TWITTER_CLIENT_ID=your-twitter-client-id

# ===========================================
# OPTIONAL: Instagram/Facebook OAuth Tokens
# ===========================================
# Option 1: Provide tokens directly (bypasses OAuth callback flow)
# Obtain tokens from Meta Developer Portal or via OAuth flow
# https://developers.facebook.com/

# Access token (required for posting)
INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token

# Your Instagram Business Account ID (found in Meta Business Suite or via API)
INSTAGRAM_ACCOUNT_ID=

# Option 2: For OAuth callback flow (if not providing tokens directly)
# INSTAGRAM_CLIENT_ID=your-meta-app-client-id
# INSTAGRAM_CLIENT_SECRET=your-meta-app-client-secret

# ===========================================
# SERVER CONFIGURATION (Optional)
# ===========================================
# PORT=13000
# HOST=0.0.0.0
