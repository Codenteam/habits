# Invoice Processor API Tests
# Test the PDF extraction, OCR, and invoice generation capabilities

@host = http://localhost:13000

###
# @name createInvoice
# Test invoice PDF generation
POST {{host}}/api/create-invoice
Content-Type: application/json

< ./test-invoice.json

###
# @name pdfExtractFromPath
# Test PDF text extraction from file path
# Requires downloading a test PDF first:
#   curl -sL -o /tmp/test.pdf "https://css4.pub/2015/textbook/somatosensory.pdf"
POST {{host}}/api/extract-pdf
Content-Type: application/json

{
  "source": "/tmp/test3.pdf",
  "sourceType": "path",
  "maxPages": 1
}

###
# @name ocrFromPath
# Test OCR from file path
# Requires creating a test image first:
#   convert -size 400x100 xc:white -font Helvetica -pointsize 36 -fill black -gravity center -annotate +0+0 "Invoice #12345" /tmp/invoice-test.png
POST {{host}}/api/process-ocr
Content-Type: application/json

{
  "source": "/tmp/invoice-test.png",
  "sourceType": "path",
  "language": "eng"
}

###
# @name ocrFromBase64
# Test OCR from base64 encoded image
# This is a 400x100 grayscale PNG with "Invoice #12345" text
POST {{host}}/api/process-ocr
Content-Type: application/json

{
  "source": "",
  "sourceType": "base64",
  "language": "eng"
}
