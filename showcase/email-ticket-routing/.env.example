# Email Ticket Routing - Environment Variables
# Copy this file to .env and fill in your values

# ============================================================================
# Gmail IMAP Credentials (for reading emails)
# ============================================================================
HABITS_GMAIL_IMAP_HOST=imap.gmail.com
HABITS_GMAIL_IMAP_PORT=993
HABITS_GMAIL_IMAP_USER=your-email@gmail.com
# Gmail App Password — NOT your regular password.
# Generate one at: https://myaccount.google.com/apppasswords
HABITS_GMAIL_IMAP_APP_PASSWORD=your-app-password-here

# ============================================================================
# OpenAI API Key (for ticket classification)
# ============================================================================
# Get your key at: https://platform.openai.com/api-keys
HABITS_OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================================================
# Shared SMTP Server (all support inboxes use the same host and port)
# ============================================================================
HABITS_SMTP_HOST=smtp.gmail.com
HABITS_SMTP_PORT=587

# ============================================================================
# Per-inbox credentials (user + password only — host/port are shared above)
# ============================================================================

# Support inbox — general support questions
HABITS_SMTP_SUPPORT_USER=support@yourcompany.com
HABITS_SMTP_SUPPORT_PASSWORD=your-support-smtp-password

# Sales inbox — pricing, plans, demos, partnerships
HABITS_SMTP_SALES_USER=sales@yourcompany.com
HABITS_SMTP_SALES_PASSWORD=your-sales-smtp-password

# Billing inbox — invoices, refunds, payment issues
HABITS_SMTP_BILLING_USER=billing@yourcompany.com
HABITS_SMTP_BILLING_PASSWORD=your-billing-smtp-password

# Feedback inbox — feature requests, suggestions, praise
HABITS_SMTP_FEEDBACK_USER=feedback@yourcompany.com
HABITS_SMTP_FEEDBACK_PASSWORD=your-feedback-smtp-password

# Spam inbox — spam, irrelevant, or abuse emails
HABITS_SMTP_SPAM_USER=spam@yourcompany.com
HABITS_SMTP_SPAM_PASSWORD=your-spam-smtp-password

# Urgent inbox — critical outages, security, SLA breaches
HABITS_SMTP_URGENT_USER=urgent@yourcompany.com
HABITS_SMTP_URGENT_PASSWORD=your-urgent-smtp-password
