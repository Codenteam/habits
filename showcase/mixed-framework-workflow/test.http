@host = localhost
@port = 3000

### Health Check
# @name healthCheck
GET http://{{host}}:{{port}}/health

?? status == 200

### List all workflows
# @name listWorkflows
GET http://{{host}}:{{port}}/misc/workflows

?? status == 200

### Get workflow details
# @name getWorkflowDetails
GET http://{{host}}:{{port}}/misc/workflow/mixed-framework-workflow

?? status == 200

### Execute Mixed Framework Workflow
# @name executeWorkflow
POST http://{{host}}:{{port}}/api/mixed-framework-workflow
Content-Type: application/json

{
  "apiUrl": "https://dummy.restapiexample.com/api/v1/employees"
}

?? status >= 200
?? status < 300
