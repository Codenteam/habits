@host = localhost
@port = 3000

### Health Check
# @name healthCheck
GET http://{{host}}:{{port}}/health

?? status == 200

### List all workflows
# @name listWorkflows
GET http://{{host}}:{{port}}/misc/workflows

?? status == 200

### Get workflow details
# @name getWorkflowDetails
GET http://{{host}}:{{port}}/misc/workflow/http-text-activepieces-workflow

?? status == 200

