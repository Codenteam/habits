@host = localhost
@port = 3000


###############################################################################
# Execute Workflow - Non-Streaming Mode
###############################################################################

### Execute workflow with input data (non-streaming)
# @name executeWorkflow
POST http://{{host}}:{{port}}/api/multi-trigger-test
Content-Type: application/json

{
  "message": "Test execution from HTTP file",
  "timestamp": "2026-01-25T14:00:00Z"
}

# Response structure assertions
?? status == 200
?? body executionId isString
?? body workflowId == multi-trigger-test
?? body startTime isString
?? body endTime isString

# Validate log-email node output - result is nested under .output.result
?? js response.parsedBody.nodeResults.find(n => n.nodeId === 'log-email').output.result.message equals workflow-completed-successfully

# Validate aggregate-input node output (passed to log-email)
# Either imap-trigger-1 OR imap-trigger-2 should trigger the workflow
?? js response.parsedBody.nodeResults.some(n => n.nodeId === 'aggregate-input') equals true
?? js response.parsedBody.nodeResults.find(n => n.nodeId === 'aggregate-input').status equals completed
?? js response.parsedBody.nodeResults.find(n => n.nodeId === 'aggregate-input').output.result.source isString
?? js response.parsedBody.nodeResults.find(n => n.nodeId === 'aggregate-input').output.result.timestamp isString
?? js ['imap-1', 'imap-2', 'direct'].includes(response.parsedBody.nodeResults.find(n => n.nodeId === 'aggregate-input').output.result.source) equals true

