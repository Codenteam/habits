# =============================================================================
# Wise Google Payment Invoice Processor - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values

# -----------------------------------------------------------------------------
# Wise Business Configuration
# -----------------------------------------------------------------------------
# Wise API Token with Full Access
# Get this from: Wise Business > Settings > API tokens
# Make sure to create a token with "Full Access" for balance statement access
WISE_API_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Wise Business Profile ID
# Find this in the URL when logged into Wise Business (e.g., /profile/12345678)
# Or via API: GET https://api.wise.com/v1/profiles
WISE_PROFILE_ID=12345678

# Currency to monitor for incoming payments
# This should match one of your Wise balance currencies (e.g., GBP, USD, EUR)
WISE_CURRENCY=GBP

# -----------------------------------------------------------------------------
# Google Drive Configuration
# -----------------------------------------------------------------------------
# Google OAuth Client ID
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_DRIVE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com

# Google OAuth Client Secret
GOOGLE_DRIVE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# Google Drive folder ID for storing invoice PDFs (optional)
# Leave empty to save to root folder
# Find folder ID in the URL: https://drive.google.com/drive/folders/FOLDER_ID_HERE
GOOGLE_DRIVE_FOLDER_ID=

# =============================================================================
# How to get your Wise API credentials:
# =============================================================================
#
# 1. Log in to your Wise Business account at https://wise.com/
#
# 2. Go to: Settings → API tokens
#
# 3. Click "Add new token" and select:
#    - Token name: "Invoice Processor" (or any name)
#    - Permissions: Full access (required for balance statement API)
#
# 4. Copy the generated token to WISE_API_TOKEN above
#
# 5. To find your Profile ID:
#    - Look at the URL when on your Wise dashboard
#    - It will be like: https://wise.com/balances/12345678
#    - The number (12345678) is your Profile ID
#
# =============================================================================
