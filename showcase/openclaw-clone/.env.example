# OpenClaw Clone - Environment Variables
# Copy this file to .env and fill in the values

# AI Configuration (required)
HABITS_INTERSECT_HOST=
HABITS_INTERSECT_API_KEY=



WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE=



# Telegram Settings
TELEGRAM_BOT_NAME=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Slack (optional)
SLACK_BOT_TOKEN=

# Email SMTP (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com

# Assistant Configuration
ASSISTANT_NAME=Claw
ASSISTANT_PERSONALITY=helpful, friendly, and proactive personal AI assistant
