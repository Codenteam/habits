            "globalConstants": "APP_NAME=MyTestApp\nAPI_VERSION=v2\nDEBUG=true\nMAX_RETRIES=3"
          }
        },
        "inputData": [
          {
            "json": {
              "existingData": "This data will be merged with constants"
            }
          }
        ]
      }
    }
  ],
  "edges": []
