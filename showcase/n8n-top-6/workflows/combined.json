{
  "id": "combined",
  "name": "Combined Workflow",
  "description": "A combined workflow: Global Constants → MCP List Tools → ChatWoot Search Contact (by email) → Evolution API Send WhatsApp Message (to phone) → ElevenLabs TTS",
  "version": "1.0.0",
  "nodes": [
    {
      "id": "global_constants_node",
      "type": "n8n",
      "position": {
        "x": 100,
        "y": 100
      },
      "data": {
        "label": "Global Constants",
        "framework": "n8n",
        "source": "npm",
        "module": "n8n-nodes-globals",
        "operation": "getConstants",
        "params": {
          "putAllInOneKey": true,
          "constantsKeyName": "config"
        },
        "credentials": {
          "globalConstantsApi": {
            "format": "string",
            "globalConstants": "APP_NAME=CombinedWorkflow\nVERSION=1.0\nMESSAGE={{habits.input.message}}"
          }
        },
        "inputData": [
          {
            "json": {}
          }
        ]
      }
    },
    {
      "id": "mcp_list_tools_node",
      "type": "n8n",
      "position": {
        "x": 200,
        "y": 100
      },
      "data": {
        "label": "MCP List Tools",
        "framework": "n8n",
        "source": "npm",
        "module": "n8n-nodes-mcp",
        "operation": "listTools",
        "params": {
          "connectionType": "cmd",
          "operation": "listTools"
        },
        "credentials": {
          "mcpClientApi": {
            "command": "{{habits.env.HABITS_MCP_COMMAND}}",
            "args": "{{habits.env.HABITS_MCP_ARGS}}",
            "environments": "{{habits.env.HABITS_MCP_ENVIRONMENTS}}"
          }
        },
        "inputData": [
          {
            "json": {}
          }
        ]
      }
    },
    {
      "id": "chatwoot_contact_node",
      "type": "n8n",
      "position": {
        "x": 300,
        "y": 100
      },
      "data": {
        "label": "ChatWoot Search Contact",
        "framework": "n8n",
        "source": "npm",
        "module": "n8n-nodes-chatwoot",
        "operation": "contactSearch",
        "params": {
          "authentication": "parametersCredentialType",
          "baseUrl": "{{habits.env.HABITS_CHATWOOT_BASE_URL}}",
          "accessToken": "{{habits.env.HABITS_CHATWOOT_ACCESS_TOKEN}}",
          "resource": "contact",
          "operation": "contactSearch",
          "accountId": "{{habits.env.HABITS_CHATWOOT_ACCOUNT_ID}}",
          "contactSearchQuery": "{{habits.input.email}}"
        },
        "inputData": [
          {
            "json": {}
          }
        ]
      }
    },
    {
      "id": "evolution_send_message_node",
      "type": "n8n",
      "position": {
        "x": 350,
        "y": 100
      },
      "data": {
        "label": "Evolution API Send Message",
        "framework": "n8n",
        "source": "npm",
        "module": "n8n-nodes-evolution-api",
        "resource": "messages-api",
        "operation": "send-text",
        "params": {
          "instanceName": "{{habits.env.HABITS_EVOLUTION_INSTANCE_NAME}}",
          "remoteJid": "{{chatwoot_contact_node.result.0.0.json.payload.0.phone_number}}",
          "messageText": "{{habits.input.message}}"
        },
        "credentials": {
          "evolutionApi": {
            "server-url": "{{habits.env.HABITS_EVOLUTION_API_URL}}",
            "apikey": "{{habits.env.HABITS_EVOLUTION_API_KEY}}",
            "integration": "WHATSAPP-BUSINESS"
          }
        },
        "inputData": [
          {
            "json": {}
          }
        ]
      }
    },
    {
      "id": "elevenlabs_tts_node",
      "type": "n8n",
      "position": {
        "x": 400,
        "y": 100
      },
      "data": {
        "label": "Text to Speech",
        "framework": "n8n",
        "source": "npm",
        "module": "@elevenlabs/n8n-nodes-elevenlabs",
        "resource": "speech",
        "operation": "textToSpeech",
        "params": {
          "voice": {
            "mode": "id",
            "value": "21m00Tcm4TlvDq8ikWAM"
          },
          "text": "{{habits.input.message}}"
        },
        "credentials": {
          "elevenLabsApi": {
            "xiApiKey": "{{habits.env.HABITS_ELEVENLABS_API_KEY}}"
          }
        },
        "inputData": [
          {
            "json": {}
          }
        ]
      }
    }
  ],
  "edges": [
    {
      "id": "edge-1",
      "source": "global_constants_node",
      "target": "mcp_list_tools_node"
    },
    {
      "id": "edge-2",
      "source": "mcp_list_tools_node",
      "target": "chatwoot_contact_node"
    },
    {
      "id": "edge-3",
      "source": "chatwoot_contact_node",
      "target": "evolution_send_message_node"
    },
    {
      "id": "edge-4",
      "source": "evolution_send_message_node",
      "target": "elevenlabs_tts_node"
    }
  ]
}
