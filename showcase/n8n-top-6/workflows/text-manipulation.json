{
  "id": "text-manipulation",
  "name": "Text Manipulation",
  "description": "Manipulate text using various operations",
  "version": "1.0.0",
  "nodes": [
    {
      "id": "text-manipulation-node",
      "type": "n8n",
      "position": { "x": 250, "y": 100 },
      "data": {
        "label": "Text Manipulation",
        "framework": "n8n",
        "source": "npm",
        "module": "n8n-nodes-text-manipulation",
        "operation": "trim",
        "params": {
          "keepOnlySet": false,
          "textsWithManipulations": {
            "textsWithManipulationsValues": [
              {
                "dataSources": {
                  "dataSource": [
                    {
                      "readOperation": "fromJSON",
                      "sourceKey": "originalText",
                      "getManipulatedData": false,
                      "skipNonString": false,
                      "writeOperation": "toJSON",
                      "destinationKey": "result"
                    }
                  ]
                },
                "manipulations": {
                  "manipulation": [
                    {
                      "action": "trim",
                      "trim": "trimBoth",
                      "characters": " "
                    }
                  ]
                }
              }
            ]
          },
          "inputData": "{{habits.input.inputData}}"
        },
        "credentials": {}
      }
    }
  ],
  "edges": []
}
