# =============================================================================
# Stripe Google Payment Invoice Processor - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values

# -----------------------------------------------------------------------------
# Stripe Configuration
# -----------------------------------------------------------------------------
# Your Stripe secret key (starts with sk_live_ or sk_test_)
STRIPE_SECRET_KEY=Secret

# Stripe webhook signing secret (starts with whsec_)
# Get this from Stripe Dashboard > Developers > Webhooks
STRIPE_WEBHOOK_SECRET=Secret

# -----------------------------------------------------------------------------
# Google Drive Configuration
# -----------------------------------------------------------------------------
# Google OAuth Client ID
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_DRIVE_CLIENT_ID=Secret

# Google OAuth Client Secret
GOOGLE_DRIVE_CLIENT_SECRET=Secret

# Google Drive folder ID for storing invoice PDFs (optional)
# Leave empty to save to root folder
# Find folder ID in the URL: https://drive.google.com/drive/folders/FOLDER_ID_HERE
GOOGLE_DRIVE_FOLDER_ID=

# =============================================================================
# How to set up Stripe webhooks:
# =============================================================================
#
# 1. Go to Stripe Dashboard → Developers → Webhooks
#
# 2. Click "Add endpoint"
#
# 3. Enter your webhook URL:
#    - Local: Use ngrok or similar for testing
#    - Production: https://your-domain.com/webhook/stripe-payment-invoice
#
# 4. Select events to listen:
#    - payment_intent.succeeded
#
# 5. Copy the "Signing secret" to STRIPE_WEBHOOK_SECRET above
#
# =============================================================================
